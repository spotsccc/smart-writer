{
  "name": "@spotsccc/smart-writer",
  "version": "0.1.0-next.0",
  "description": "Provider-neutral article writing orchestration",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spotsccc/smart-writer.git"
  },
  "bugs": {
    "url": "https://github.com/spotsccc/smart-writer/issues"
  },
  "homepage": "https://github.com/spotsccc/smart-writer#readme",
  "scripts": {
    "build": "pkgroll --clean-dist --target=node22",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "pack:check": "npm run build && node scripts/check-package.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "pkgroll": "^2.27.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  }
}
